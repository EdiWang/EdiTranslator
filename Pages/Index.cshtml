@page
@model IndexModel
@{
    ViewData["Title"] = "Translator";
}

<div id="error-container" class="error-message mb-4" style="display: none;"></div>

<div class="row">
    <div class="col-lg-9">
        <form id="translatorForm">
            <div class="row">
                <div class="col-md-12 col-lg-6">
                    <section class="translator-text-container">
                        <div class="d-flex lang-selector-bar">
                            <fluent-dropdown id="sourceLanguage" title="Source language" value="auto-detect">
                                <fluent-listbox>
                                    @foreach (var lang in IndexModel.LanguageList)
                                    {
                                        <fluent-option value="@lang.Code">@lang.Name</fluent-option>
                                    }
                                </fluent-listbox>
                            </fluent-dropdown>

                            <fluent-button type="button" appearance="secondary" id="swapLanguages">Swap</fluent-button>

                            <fluent-dropdown id="targetLanguage" title="Target language" value="en-US">
                                <fluent-listbox>
                                    @foreach (var lang in IndexModel.LanguageList.Where(l => l.Code != "auto-detect"))
                                    {
                                        <fluent-option value="@lang.Code">@lang.Name</fluent-option>
                                    }
                                </fluent-listbox>
                            </fluent-dropdown>
                        </div>
                        <div>
                            <fluent-textarea
                                id="sourceText" 
                                class="source-text" 
                                placeholder="Enter text" 
                                maxlength="@IndexModel.MaxTextLength" 
                                rows="10"
                                block
                                resize="vertical"
                                spellcheck="false">
                            </fluent-textarea>
                        </div>
                        <div class="char-count">
                            <span id="charCount">0</span> / @IndexModel.MaxTextLength character(s)
                        </div>
                    </section>
                    <div class="mt-2">
                        <fluent-button type="button" appearance="primary" class="me-2" id="translateBtn" title="CTRL + ENTER">
                            Translate
                        </fluent-button>
                        <fluent-button type="button" appearance="secondary" id="clearBtn">Clear</fluent-button>
                    </div>
                    <div class="tips mt-3">
                        <span>Tip: Press CTRL + Enter to submit the form.</span>
                    </div>
                </div>
                <div class="col-md-12 col-lg-6">
                    <section class="translator-text-container">
                        <div>
                            <fluent-dropdown id="deploymentName" title="Deployment" value="@Model.DeploymentList.FirstOrDefault()?.Name">
                                <fluent-listbox>
                                    @foreach (var deployment in Model.DeploymentList)
                                    {
                                        <fluent-option value="@deployment.Name">@deployment.DisplayName</fluent-option>
                                    }
                                </fluent-listbox>
                            </fluent-dropdown>
                        </div>
                        <div class="translated-text-container" id="translatedText"></div>
                        <div class="char-count">
                            <span id="translatedCharCount">0</span> character(s)
                        </div>
                    </section>
                    <div class="mt-2">
                        <fluent-button type="button" appearance="primary" id="copyBtn" disabled>
                            Copy
                        </fluent-button>
                    </div>
                </div>
            </div>
        </form>
    </div>
    <div class="col-lg-3">
        <h3>History</h3>
        <div id="translationHistory"></div>
    </div>
</div>

@section Scripts {
    <script>
        // Language and deployment lists for JavaScript
        window.languageList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(IndexModel.LanguageList));
        window.deploymentList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DeploymentList));
    </script>
}
