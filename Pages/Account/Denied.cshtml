@page
@model Edi.Translator.Pages.Account.DeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<section class="auth-panel">
    <h2>Access denied</h2>
    <p>This Microsoft account is not allowed to access Edi's Translator.</p>
    <form method="post" asp-page="/Account/Logout">
        <fluent-button type="submit" appearance="primary">Sign in with another account</fluent-button>
    </form>
</section>
